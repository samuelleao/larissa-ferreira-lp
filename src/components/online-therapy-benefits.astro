---
export interface Props {
  class?: string
}

const { class: className } = Astro.props

const benefitCards = [
  {
    title: "Terapia sem sair de casa",
    description: "A terapia te ajuda a transformar sobrecarga em passos claros e viáveis para o seu momento.",
    image: "/first-contact.png",
    benefitLabel: "Benefício 1",
    insight: "Atendimento online com a mesma efetividade da presencial.",
  },
  {
    title: "Acolhimento",
    description: "Você organiza sua rotina emocional com direção prática para manter constância no processo.",
    image: "/benefit-2.png",
    benefitLabel: "Benefício 2",
    insight: "Escuta ativa e vínculo terapêutico no seu ritmo.",
  },
  {
    title: "Processo estruturado e personalizado",
    description: "Você expressa o que sente com liberdade e converte isso em mudanças reais na sua rotina.",
    image: "/benefit-3.png",
    benefitLabel: "Benefício 3",
    insight: "Plano claro com metas adaptadas ao seu momento de vida.",
  },
] as const
---

<section id="beneficios-online" class:list={["relative left-1/2 w-screen -translate-x-1/2 py-16 md:py-24 lg:py-28 px-4 transition-colors duration-700 ease-out bg-white", className]}>
  <div class="mx-auto grid w-full max-w-6xl gap-10 lg:grid-cols-[minmax(0,420px)_minmax(0,1fr)] lg:items-start lg:gap-12">
    <div class="flex flex-col gap-4 lg:sticky lg:top-[50svh] lg:-translate-y-1/2">
      <span class="landing-reveal inline-flex items-center gap-3 text-sm font-mono text-foreground" data-reveal style="--reveal-delay: 20ms;">
        <span class="h-px w-8 bg-muted-foreground"></span>
        Atendimento Online
      </span>
      <h2 class="landing-reveal font-heading text-4xl font-medium leading-tight text-foreground md:text-5xl" data-reveal style="--reveal-delay: 100ms;">
        Bons motivos para investir em <span class="font-light italic text-muted-foreground">terapia online</span>
      </h2>
      <p class="landing-reveal max-w-md text-base text-muted-foreground" data-reveal style="--reveal-delay: 180ms;">
        Cuide da sua saude emocional com praticidade, seguranca e no seu tempo.
      </p>
    </div>

    <div class="relative w-full">
      <div class="sticky top-20 z-10 md:top-[50svh] md:-translate-y-1/2">
        <div class="relative mx-auto min-h-[560px] w-full max-w-[640px] sm:min-h-[520px] md:min-h-[420px]">
          {benefitCards.map((card, index) => (
            <article
              class:list={[
                "absolute inset-0 rounded-3xl border border-border/70 bg-white p-3 shadow-[0_0.602187px_1.80656px_-1.25px_rgba(0,0,0,0.07),0_2.28853px_6.8656px_-2.5px_rgba(0,0,0,0.06),0_10px_30px_-3.75px_rgba(0,0,0,0.03)] transition-all duration-700 ease-out md:p-4",
                index === 0 && "pointer-events-auto opacity-100 translate-y-0 scale-100 z-30 shadow-[0_18px_40px_rgba(15,23,42,0.12)]",
                index === 1 && "pointer-events-none opacity-100 translate-y-6 scale-[0.985] z-20 shadow-sm",
                index === 2 && "pointer-events-none opacity-100 translate-y-10 scale-[0.97] z-10 shadow-sm",
              ]}
              data-stack-card
              data-index={index}
            >
              <div class="grid h-full gap-3 md:grid-cols-[minmax(0,230px)_1fr] md:gap-4">
                <div class="h-full overflow-hidden rounded-2xl border border-border/40 bg-white">
                  <img
                    src={card.image}
                    alt={card.title}
                    width="230"
                    height="360"
                    loading="lazy"
                    class="h-full w-full object-cover"
                  />
                </div>

                <div class="flex h-full flex-col gap-2 py-1 md:pr-3">
                  <div class="space-y-2 rounded-xl bg-white">
                    <p class="text-sm leading-5 text-muted-foreground/80">{card.benefitLabel}</p>
                    <h3 class="font-heading text-lg font-semibold tracking-[-0.3px] text-foreground md:text-[24px] md:leading-8">
                      {card.title}
                    </h3>
                    <p class="max-w-[34ch] text-sm leading-6 text-muted-foreground">
                      {card.description}
                    </p>
                  </div>

                  <div class="mt-auto flex items-center justify-between rounded-xl border border-border/60 bg-white/90 px-3 py-2">
                    <div class="inline-flex items-center gap-2 text-sm text-muted-foreground">
                      <span class="inline-flex size-4 items-center justify-center rounded-full border border-border text-[10px]">+</span>
                      Curiosidade
                    </div>
                    <div class="inline-flex max-w-[180px] items-center gap-2 rounded-lg bg-muted/50 px-2 py-1">
                      <img src={card.image} alt={card.benefitLabel} width="20" height="20" loading="lazy" class="size-5 rounded-md object-cover" />
                      <span class="truncate text-xs font-medium text-foreground">{card.insight}</span>
                    </div>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="grid" aria-hidden="true">
        {benefitCards.map((_, index) => (
          <div class="h-[42svh] md:h-[50svh]" data-stack-trigger data-index={index}></div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { observeRevealsIn } from "@/lib/landing-reveal"
  observeRevealsIn("#beneficios-online")

  const section = document.querySelector<HTMLElement>("#beneficios-online")
  if (section) {
    const cards = Array.from(section.querySelectorAll<HTMLElement>("[data-stack-card]"))
    const triggers = Array.from(section.querySelectorAll<HTMLElement>("[data-stack-trigger]"))
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches
    const sectionBackgrounds = ["bg-white", "bg-[#F1E4D7]", "bg-[#E8E1DA]"]

    const resetClasses = [
      "pointer-events-none",
      "pointer-events-auto",
      "opacity-0",
      "opacity-100",
      "translate-y-16",
      "translate-y-10",
      "translate-y-6",
      "translate-y-8",
      "translate-y-0",
      "scale-[0.965]",
      "scale-100",
      "scale-[0.985]",
      "scale-[0.97]",
      "z-10",
      "z-20",
      "z-30",
      "shadow-sm",
      "shadow-[0_18px_40px_rgba(15,23,42,0.12)]",
    ]

    const activate = (index: number) => {
      section.classList.remove(...sectionBackgrounds)
      section.classList.add(sectionBackgrounds[index] ?? sectionBackgrounds[0])

      cards.forEach((card, cardIndex) => {
        card.classList.remove(...resetClasses)

        const diff = cardIndex - index
        if (diff === 0) {
          card.classList.add("pointer-events-auto", "opacity-100", "translate-y-0", "scale-100", "z-30", "shadow-[0_18px_40px_rgba(15,23,42,0.12)]")
          return
        }

        if (diff === 1) {
          card.classList.add("pointer-events-none", "opacity-100", "translate-y-6", "scale-[0.985]", "z-20", "shadow-sm")
          return
        }

        if (diff === 2) {
          card.classList.add("pointer-events-none", "opacity-100", "translate-y-10", "scale-[0.97]", "z-10", "shadow-sm")
          return
        }

        card.classList.add("pointer-events-none", "opacity-0", "translate-y-16", "scale-[0.965]", "shadow-sm")
      })
    }

    if (cards.length && triggers.length) {
      if (reducedMotion) {
        activate(0)
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return
              const indexValue = Number(entry.target.getAttribute("data-index") || 0)
              activate(indexValue)
            })
          },
          {
            threshold: 0.35,
            rootMargin: "-10% 0px -10% 0px",
          }
        )

        triggers.forEach((trigger) => observer.observe(trigger))
      }
    }
  }
</script>
