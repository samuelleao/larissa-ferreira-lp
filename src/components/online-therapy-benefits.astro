---
import { ArrowRight, Atom, ShieldCheck, Star, Zap } from "lucide-react"

export interface Props {
  class?: string
}

const { class: className } = Astro.props

const avatars = [
  "https://www.figma.com/api/mcp/asset/f59eac9a-c5d8-48a3-835d-f2d02e7cd956",
  "https://www.figma.com/api/mcp/asset/8dc2b6ae-6fa0-4755-a6d1-f0f5b66eac1f",
  "https://www.figma.com/api/mcp/asset/4e52afda-4fa7-4eaa-9cd4-5b3fa75921e8",
  "https://www.figma.com/api/mcp/asset/efe31e5d-6bff-4156-82d7-d6f58e324ff9",
  "https://www.figma.com/api/mcp/asset/2ebee95f-83af-46e9-9c02-ef9366d8cf66",
]
---

<section id="beneficios-online" class:list={["mx-auto w-full max-w-[1400px] py-16 md:py-24 lg:py-28 px-4", className]}>
  <div class="mx-auto flex w-full max-w-5xl flex-col items-center">
    <div class="flex max-w-xl flex-col items-center gap-4 text-center">
      <span class="landing-reveal inline-flex items-center gap-3 text-sm font-mono text-foreground" data-reveal style="--reveal-delay: 20ms;">
        <span class="h-px w-8 bg-muted-foreground"></span>
        Atendimento Online
      </span>      <h2 class="landing-reveal font-heading text-4xl font-medium leading-tight text-foreground md:text-5xl" data-reveal style="--reveal-delay: 100ms;">
        Bons motivos para investir em <span class="font-light italic text-muted-foreground">terapia online</span>
      </h2>
      <p class="landing-reveal max-w-md text-base text-muted-foreground" data-reveal style="--reveal-delay: 180ms;">
        Cuide da sua saude emocional com praticidade, seguranca e no seu tempo.
      </p>
    </div>

    <div class="mt-12 grid w-full grid-cols-1 gap-6 md:grid-cols-2">
      <article class="landing-reveal flex h-full flex-col rounded-xl py-8" data-reveal style="--reveal-delay: 260ms;">
        <div class="mb-7 flex flex-wrap gap-2">
          <span class="inline-flex items-center gap-1 rounded-md border border-border px-2 py-1 text-xs text-foreground">
            <Zap className="icon-draw size-3.5" aria-hidden="true" />
            Pratico
          </span>
          <span class="inline-flex items-center gap-1 rounded-md border border-border px-2 py-1 text-xs text-foreground">
            <ShieldCheck className="icon-draw size-3.5" aria-hidden="true" />
            Seguro
          </span>
          <span class="inline-flex items-center gap-1 rounded-md border border-border px-2 py-1 text-xs text-foreground">
            <Atom className="icon-draw size-3.5" aria-hidden="true" />
            Acessivel
          </span>
        </div>
        <h3 class="font-heading text-2xl font-semibold text-foreground">Terapia sem sair de casa</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Faca suas sessoes de onde estiver, com total conforto e privacidade. Ideal para rotinas corridas ou para quem
          prefere um ambiente mais acolhedor.
        </p>
        <a href="#marcar-consulta" class="mt-6 inline-flex items-center gap-2 text-base font-medium text-foreground">
          Ver como funciona
          <ArrowRight className="icon-draw size-4" aria-hidden="true" />
        </a>
      </article>

      <article class="landing-reveal flex h-full flex-col rounded-xl py-8" data-reveal style="--reveal-delay: 340ms;">
        <div class="mb-7 inline-flex w-fit flex-col gap-1">
          <div class="flex items-center gap-1 text-amber-400">
            {Array.from({ length: 5 }).map(() => (
              <Star className="size-4 fill-current" aria-hidden="true" />
            ))}
          </div>
          <p class="text-sm text-muted-foreground">+ de 20 pacientes atendidos</p>
        </div>
        <h3 class="font-heading text-2xl font-semibold text-foreground">Resultados reais na sua rotina</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          A terapia online e tao eficaz quanto a presencial e se adapta ao seu dia a dia, aumentando a consistencia e
          os resultados ao longo do tempo.
        </p>
      </article>

      <article class="landing-reveal flex h-full flex-col rounded-xl py-8" data-reveal style="--reveal-delay: 420ms;">
        <div class="mb-7 flex items-start justify-between gap-3">
          <h3 class="font-heading text-2xl font-semibold text-foreground">Acolhimento</h3>
          <span class="inline-flex items-center rounded-md border border-border px-2 py-1 text-xs text-foreground">
            Atendimento Humanizado
          </span>
        </div>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Cada pessoa e unica. O processo terapeutico e construido com escuta ativa, empatia e respeito ao seu tempo e
          as suas necessidades.
        </p>
        <div class="relative mt-8 flex items-center justify-between">
          {avatars.map((avatar, index) => (
            <div
              class="landing-reveal-media size-14 shrink-0 overflow-hidden rounded-full"
              data-reveal-media
              style={`--reveal-delay: ${index * 70}ms;`}
            >
              <img
                src={avatar}
                alt={`Avatar ilustrado ${index + 1}`}
                width="56"
                height="56"
                loading="lazy"
                class="landing-reveal-media__img size-14 rounded-full object-cover"
              />
            </div>
          ))}
        </div>
      </article>

      <article class="landing-reveal flex h-full flex-col rounded-xl py-8" data-reveal style="--reveal-delay: 500ms;">
        <div class="mb-7 flex justify-end">
          <span class="inline-flex items-center rounded-md border border-border px-2 py-1 text-xs text-foreground">
            Exclusivo
          </span>
        </div>
        <h3 class="font-heading text-2xl font-semibold text-foreground">Processo estruturado e personalizado</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          As sessoes seguem uma abordagem organizada, com objetivos claros e evolucao continua, sempre respeitando o
          seu momento.
        </p>
        <a href="#marcar-consulta" class="mt-6 inline-flex items-center gap-2 text-base font-medium text-foreground">
          Entenda o processo
          <ArrowRight className="icon-draw size-4" aria-hidden="true" />
        </a>
      </article>
    </div>
  </div>
</section>

<script>
  import { observeRevealsIn, initIconDrawIn } from "@/lib/landing-reveal"
  observeRevealsIn("#beneficios-online")
  initIconDrawIn("#beneficios-online")
</script>
