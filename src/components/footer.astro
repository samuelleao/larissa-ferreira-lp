---
export interface Props {
  class?: string
}

import { ArrowUp } from "lucide-react"
import { Button } from "./ui/button"
const { class: className } = Astro.props

const currentYear = new Date().getFullYear()

const navigationLinks = [
  { href: "#inicio", label: "Início" },
  { href: "#quem-sou", label: "Quem sou" },
  { href: "#abordagem", label: "Abordagem" },
  { href: "#processo", label: "Processo" },
] as const

const supportLinks = [
  { href: "#beneficios-online", label: "Atendimento online" },
  { href: "#perguntas-frequentes", label: "Perguntas frequentes" },
  { href: "#blog", label: "Conteúdos" },
  { href: "#marcar-consulta", label: "Marcar consulta" },
] as const
---

<footer class:list={["mx-auto  relative mt-16 w-full max-w-[900px] overflow-hidden    text-zinc-100", className]}>

  <section id="contato" class="px-6 py-10 md:px-10">
    <div id="marcar-consulta" class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
      <div class="landing-reveal" data-reveal style="--reveal-delay: 40ms;">
        <p class="text-lg font-semibold text-black">Larissa Ferreira</p>
        <p class="mt-2 max-w-sm text-sm leading-relaxed text-muted-foreground">
          Psicóloga clínica com atendimento online, acolhedor e baseado em Terapia Cognitivo-Comportamental.
        </p>
      </div>
     
  </section>

  

  <div class=" md:px-10 grid md:grid-cols-2 gap-4 px-6 ">


    <div class="landing-reveal" data-reveal style="--reveal-delay: 100ms;">
      <p class="text-sm font-semibold text-mauve-600">Navegação</p>
      <ul class="mt-3 space-y-2">
        {
          navigationLinks.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-muted-foreground no-underline transition hover:text-mauve-600">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="landing-reveal" data-reveal style="--reveal-delay: 160ms;">
      <p class="text-sm font-semibold text-mauve-600">Informações úteis</p>
      <ul class="mt-3 space-y-2">
        {
          supportLinks.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-muted-foreground no-underline transition hover:text-mauve-600">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="landing-reveal flex flex-col gap-8 px-6 py-20 text-xs text-zinc-500 md:flex-row md:items-center md:justify-between md:px-10" data-reveal style="--reveal-delay: 80ms;">
    <p>© {currentYear} Larissa Ferreira. Todos os direitos reservados.</p>
    <Button variant="outline" size="sm" className="w-max">
      <ArrowUp aria-hidden="true" />
      Voltar ao topo
    </Button>
  </div>
</footer>
<img
src="/footer.png"
alt="Imagem de destaque do atendimento online"
class=" bottom-0 w-full z-10 object-cover  "
loading="lazy"
/>

<script>
  import { observeRevealsIn } from "@/lib/landing-reveal"
  observeRevealsIn("footer")
</script>
