---
export interface Props {
  class?: string
}

const { class: className } = Astro.props

const currentYear = new Date().getFullYear()

const navigationLinks = [
  { href: "#inicio", label: "Início" },
  { href: "#quem-sou", label: "Quem sou" },
  { href: "#abordagem", label: "Abordagem" },
  { href: "#processo", label: "Processo" },
] as const

const supportLinks = [
  { href: "#beneficios-online", label: "Atendimento online" },
  { href: "#perguntas-frequentes", label: "Perguntas frequentes" },
  { href: "#blog", label: "Conteúdos" },
  { href: "#marcar-consulta", label: "Marcar consulta" },
] as const
---

<footer class:list={["mx-auto mt-16 w-full max-w-[1400px] overflow-hidden rounded-2xl   text-zinc-100", className]}>

  <section id="contato" class="border-y border-black/10 px-6 py-10 md:px-10">
    <div id="marcar-consulta" class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
      <div class="max-w-xl">
        <p class="text-xs uppercase tracking-[0.2em] text-zinc-400">Contato</p>
        <h2 class="mt-2 font-heading text-2xl font-medium text-black md:text-3xl">Vamos iniciar seu processo terapêutico?</h2>
        <p class="mt-2 text-sm text-zinc-300">
          Se você sentiu que este espaço faz sentido para o seu momento, o próximo passo é agendar a primeira conversa.
        </p>
      </div>
      <a
        href="#inicio"
        class="inline-flex items-center justify-center rounded-full border border-black/20 bg-black px-6 py-3 text-sm font-semibold text-zinc-900 no-underline transition hover:bg-zinc-200"
      >
        Quero agendar minha sessão
      </a>
    </div>
  </section>

  <div class="grid gap-8 px-6 py-10 md:grid-cols-3 md:px-10">
    <div>
      <p class="text-lg font-semibold text-black">Larissa Ferreira</p>
      <p class="mt-2 max-w-sm text-sm leading-relaxed text-zinc-400">
        Psicóloga clínica com atendimento online, acolhedor e baseado em Terapia Cognitivo-Comportamental.
      </p>
    </div>

    <div>
      <p class="text-sm font-semibold text-mauve-600">Navegação</p>
      <ul class="mt-3 space-y-2">
        {
          navigationLinks.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-zinc-400 no-underline transition hover:text-mauve-600">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold text-mauve-600">Informações úteis</p>
      <ul class="mt-3 space-y-2">
        {
          supportLinks.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-zinc-400 no-underline transition hover:text-mauve-600">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="flex flex-col gap-2 border-t border-black/10 px-6 py-4 text-xs text-zinc-500 md:flex-row md:items-center md:justify-between md:px-10">
    <p>© {currentYear} Larissa Ferreira. Todos os direitos reservados.</p>
    <a href="#inicio" class="text-zinc-500 no-underline transition hover:text-mauve-600">Voltar ao topo</a>
  </div>
</footer>
