---
import { AudioLines, Share2, Sunrise } from "lucide-react"

export interface Props {
  class?: string
}

const { class: className } = Astro.props

type Step = {
  title: string
  description: string
  icon: typeof Share2
}

const steps: Step[] = [
  {
    title: "Clareza do próximo passo",
    description: "Você entende com precisão o que fazer agora, sem sobrecarga mental.",
    icon: Share2,
  },
  {
    title: "Plano simples para o dia",
    description: "Organizamos seu processo em ações possíveis para manter consistência.",
    icon: Sunrise,
  },
  {
    title: "Expressão livre do que sente",
    description: "Você fala com liberdade sobre o que está vivendo e transforma isso em direção.",
    icon: AudioLines,
  },
]
---

<section id="processo" class:list={["mx-auto w-full max-w-[1400px] py-16 md:py-24 lg:py-[98px] bg-primary/10 rounded-2xl -translate-y-50 backdrop-blur-2xl px-4", className]}>
  <div class="flex flex-col items-center gap-14 md:gap-20 lg:gap-[72px]">
   <div class="flex w-full max-w-[1080px] flex-col items-start gap-4">
    <span class="landing-reveal inline-flex items-center gap-3 text-sm font-mono text-foreground" data-reveal style="--reveal-delay: 20ms;">
      <span class="h-px w-8 bg-muted-foreground"></span>
      Processo
    </span>

    <p class="landing-reveal max-w-[440px] text-balance text-[40px] leading-tight tracking-[-1.2px] text-muted-foreground md:text-[44px]" data-reveal style="--reveal-delay: 120ms;">
      Cuidar de si não precisa ser confuso
    </p>

    <h2 class="landing-reveal w-full max-w-[980px] font-heading text-4xl font-medium leading-tight tracking-[-1.8px] text-foreground md:text-5xl lg:text-4xl lg:tracking-[-2px]" data-reveal style="--reveal-delay: 180ms;">
      Terapia estruturada de forma simples
    </h2>
   </div>

    <div class="grid w-full max-w-[1080px] grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        steps.map((step, index) => (
          <article class="landing-reveal rounded-2xl bg-white p-7 md:p-8" data-reveal style={`--reveal-delay: ${220 + index * 80}ms;`}>
            <div class="mb-20 md:mb-24">
              <step.icon className="icon-draw size-7 text-foreground" aria-hidden="true" />
            </div>

            <div class="flex flex-col gap-3 leading-normal">
              <p class="w-full font-heading text-[30px] font-semibold tracking-[-0.8px] text-foreground md:text-[22px]">
                {step.title}
              </p>
              <p class="w-full max-w-[320px] text-[20px] tracking-[-0.64px] text-muted-foreground">{step.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { initIconDrawIn, observeRevealsIn } from "@/lib/landing-reveal"
  observeRevealsIn("#processo")
  initIconDrawIn("#processo")
</script>
