---
import { Button } from './ui/button'

export interface Props {
  class?: string
}

const { class: className } = Astro.props

---

<section
  id="inicio"
  class:list={["relative left-1/2 w-screen -translate-x-1/2", className]}
>
  <div class="relative min-h-[calc(100svh+10rem)] overflow-hidden">
    <img
      src="/cover-video.png"
      alt="Imagem de destaque do atendimento online"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/35"></div>

    <div class="relative z-10 flex min-h-screen flex-col justify-end p-6 pt-24 md:p-10 md:pt-28">
     

      <div class="mx-auto flex max-w-4xl flex-col items-center text-center">
      

        <h1 class="font-heading text-5xl font-medium tracking-[-2px] text-white md:text-6xl lg:text-7xl">
          <span class="font-heading italic font-light">Olá</span>, sinta-se
          <br />
          à vontade
        </h1>

        <p class="mt-6 max-w-xl text-sm leading-relaxed text-white/85 md:text-base w-[340px]">
          Aqui é um espaço onde vou te auxiliar a encontrar melhores caminhos
        </p>

      </div>

      <div class="mx-auto my-8 w-full max-w-2xl rounded-xl border border-white/5 bg-black/10 p-3 backdrop-blur-md md:flex md:items-center md:justify-between md:gap-4">
        <p class="mb-3 text-center text-sm text-white/90 md:mb-0 md:text-left">
          Atendimento online com acolhimento e clareza para o seu processo.
        </p>
        <div class="flex items-center justify-center gap-2 md:justify-end">
          <Button
            variant="default"
            size="lg"
            className="mx-auto pl-0 bg-white text-black"
          >
            <span class="relative flex size-9 items-center justify-center rounded-full bg-white text-black">
              <span class="absolute inline-flex size-full animate-ping rounded-full bg-white/60"></span>
              <span class="relative ml-0.5 text-xs">▶</span>
            </span>
            Iniciar
          </Button>
        </div>
      </div>
    </div>
  </div>
  <div class="bg-white h-10 rounded-t-3xl w-full absolute bottom-0 "></div>

</section>
