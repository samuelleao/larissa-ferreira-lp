---
export interface Props {
  class?: string
}

const { class: className } = Astro.props

const aboutParagraph =
  "Meu nome é Ana Larissa, <strong>mas pode me chamar de Lari</strong>. Sou psicóloga clínica e trabalho com a Terapia Cognitivo-Comportamental, uma abordagem baseada em evidências científicas."

const aboutParagraph2 = "Iniciei minha atuação durante a pandemia, um período desafiador que reforçou ainda mais a importância do cuidado com a saúde mental. Foi nesse contexto que me conectei profundamente com o atendimento online, e desde então sigo atendendo pessoas de diferentes lugares, com acolhimento, ética e compromisso."

const aboutParagraph3 = "Acredito que cada pessoa tem uma história única, e por isso <strong>cada processo terapêutico também precisa ser construído de forma única.</strong></p>"

---

<section id="quem-sou" class:list={["mx-auto w-full max-w-[1400px]  py-20 md:py-24 px-8", className]}>
  <div class="mx-auto flex-col w-full  items-start gap-12 lg:flex-row lg:gap-24">
   

    <div class="grid grid-cols-1 lg:grid-cols-3 lg:gap-20 place-items-start">
      <div class="  lg:sticky lg:top-20">
        <span class="mb-4  inline-flex items-center gap-3 text-sm font-mono text-foreground">
          <span class="w-8 h-px bg-muted-foreground"></span>
      Sobre mim
        </span>
        <h2 class="font-heading text-4xl leading-tight tracking-[-0.04em] font-medium text-foreground md:text-5xl">Quem sou eu?</h2>
      </div>
      
          <div class="relative w-full max-w-xl mx-auto">
            <div class="mt-4 space-y-4 text-base leading-relaxed tracking-[-0.02em] text-muted-foreground mb-8">
              <p set:html={aboutParagraph} class="[&_strong]:font-medium [&_strong]:text-foreground" />
            </div>
            <div class="mt-8 space-y-4 text-base leading-relaxed tracking-[-0.02em] text-muted-foreground mb-8">
              <p class="text-balance">{aboutParagraph2}</p>
            </div>
      
      
            <div class="mt-8 space-y-4 text-4xl leading-tight tracking-[-0.04em]  text-muted-foreground mb-8">
              <p set:html={ aboutParagraph3 } class="text-balance [&_strong]:font-medium! [&_strong]:text-foreground"/>
            </div>
      
        
          </div>

          <div class="flex w-full  flex-1 flex-col gap-4 lg:sticky lg:top-20">
            <div
              class="about-image-wrap h-[432px] w-full rounded-2xl bg-muted relative mx-auto overflow-hidden reveal-media"
              data-about-reveal
            >
              <!-- Imagem da psicóloga -->
              <img
                src="/about.png"
                alt="Larissa Ferreira"
                class="about-image w-full h-full object-cover rounded-2xl"
              />
              <!-- Nome da psicóloga por cima da imagem -->
             
            </div>
            
          </div>

    </div>


 

  </div>
</section>

<style>
  #quem-sou .reveal-media {
    opacity: 0;
    transform: translate3d(0, 26px, 0);
    transition:
      opacity 650ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }

  #quem-sou .about-image {
    transform: scale(1.085) translate3d(0, 10px, 0);
    filter: saturate(0.92) blur(2px);
    transition:
      transform 1100ms cubic-bezier(0.22, 1, 0.36, 1) 80ms,
      filter 900ms ease-out 80ms;
    will-change: transform, filter;
  }

  #quem-sou .about-name {
    opacity: 0;
    transform: translate3d(0, 18px, 0);
    transition:
      opacity 520ms cubic-bezier(0.22, 1, 0.36, 1) 260ms,
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1) 260ms;
    will-change: opacity, transform;
  }

  #quem-sou .reveal-media.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  #quem-sou .reveal-media.is-visible .about-image {
    transform: scale(1) translate3d(0, 0, 0);
    filter: saturate(1) blur(0);
  }

  #quem-sou .reveal-media.is-visible .about-name {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    #quem-sou .reveal-media,
    #quem-sou .about-image,
    #quem-sou .about-name {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }
</style>

<script>
  (() => {
    type WindowWithReveal = Window & { __landingRevealObserver?: IntersectionObserver };
    const globalWindow = window as WindowWithReveal;
    const target = document.querySelector<HTMLElement>("#quem-sou [data-about-reveal]");
    if (!target) return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      target.classList.add("is-visible");
      return;
    }

    if (!globalWindow.__landingRevealObserver) {
      globalWindow.__landingRevealObserver = new IntersectionObserver(
        (entries, observer) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        },
        {
          root: null,
          threshold: 0.2,
          rootMargin: "0px 0px -12% 0px",
        }
      );
    }

    const observer = globalWindow.__landingRevealObserver;
    if (!observer) return;
    observer.observe(target);
  })();
</script>
