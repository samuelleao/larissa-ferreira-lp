---
export interface Props {
  class?: string
}

const { class: className } = Astro.props
const avatarImage = "https://www.figma.com/api/mcp/asset/3e8fc2fb-5775-4700-a439-f0e1bf1a3d26"
import {
  AlarmClockOff,
  BadgeAlert,
  BatteryLow,
  Brain,
  CloudAlert,
  Target,
  Waves,
} from "lucide-react"

const emotionalSigns = [
  { label: "Cansaço constante", icon: BatteryLow },
  { label: "Se cobrar demais", icon: Target },
  { label: "Medo do futuro", icon: CloudAlert },
  { label: "Incerteza", icon: BadgeAlert },
  { label: "Sensação de esgotamento", icon: AlarmClockOff },
  { label: "Ansiedade", icon: Brain },
  { label: "Crises de ansiedade", icon: Waves },
]
---

<section id="emocoes" class:list={["max-w-[1400px] mx-auto w-full py-10 md:py-40 px-4", className]}>
  <div class="flex flex-col-reverse max-w-xl  lg:gap-20 mx-auto ">
    <img src="/brain.png" alt="Imagem de um cérebro" class="w-full h-full object-cover">
   <div class="col-start-2 mx-auto sticky top-20   bg-linear-to-b from-white/90 to-transparent">
    <span class="mb-4 inline-flex items-center gap-3 text-sm font-mono text-foreground reveal" data-reveal style="--reveal-delay: 20ms;">
      <span class="w-8 h-px bg-muted-foreground"></span>
      Emoções
    </span>
    <p class="max-w-[562px] font-heading font-medium text-4xl leading-tight tracking-[-1.92px] text-foreground md:text-5xl reveal" data-reveal style="--reveal-delay: 120ms;">
      Se você chegou até aqui, talvez esteja
      <span class="font-light text-muted-foreground reveal" data-reveal style="--reveal-delay: 200ms;"> carregando muita coisa...</span>
    </p>


    <div class="w-full mt-10">
      <div class="flex items-start gap-2.5">


        <div class="flex min-w-0 flex-1 flex-col justify-center rounded-xl   py-4  reveal" data-reveal style="--reveal-delay: 380ms;">
          <!-- <p class="mb-4 text-[19px] leading-6 font-semibold text-foreground reveal" data-reveal style="--reveal-delay: 460ms;">Isso soa familiar?</p> -->

          <ul class="flex flex-wrap gap-x-3 gap-y-2">
            {emotionalSigns.map((item, index) => (
              <li
                class="inline-flex min-h-[24px] items-center gap-1.5 rounded-full border border-zinc-200 bg-white px-2.5 py-1 text-xs leading-tight font-semibold text-foreground reveal"
                data-reveal
                style={`--reveal-delay: ${560 + index * 110}ms;`}
              >
                <item.icon className="size-3.5 shrink-0 text-muted-foreground icon-draw" aria-hidden="true" />
                <span>{item.label}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #emocoes .reveal {
    opacity: 0;
    transform: translate3d(0, 20px, 0) scale(0.985);
    transition:
      opacity 560ms cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0ms),
      transform 560ms cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  #emocoes .reveal.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }

  #emocoes .icon-draw.is-draw-ready :is(path, line, polyline, polygon, circle, rect, ellipse) {
    stroke-dasharray: var(--stroke-length, 1);
    stroke-dashoffset: var(--stroke-length, 1);
    transition: none;
  }

  #emocoes .reveal.is-visible .icon-draw.is-draw-ready :is(path, line, polyline, polygon, circle, rect, ellipse) {
    stroke-dashoffset: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    #emocoes .reveal,
    #emocoes .reveal.is-visible {
      opacity: 1;
      transform: none;
      transition: none;
    }

    #emocoes .icon-draw.is-draw-ready :is(path, line, polyline, polygon, circle, rect, ellipse) {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
      transition: none;
    }

  }
</style>

<script>
  (() => {
    type WindowWithReveal = Window & { __landingRevealObserver?: IntersectionObserver };
    const globalWindow = window as WindowWithReveal;
    const targets = document.querySelectorAll("#emocoes [data-reveal]");
    if (!targets.length) return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      targets.forEach((node) => node.classList.add("is-visible"));
      return;
    }

    const observer = globalWindow.__landingRevealObserver;
    if (!observer) {
      targets.forEach((node) => node.classList.add("is-visible"));
      return;
    }

    const setupIconDraw = (icon: SVGElement, delayMs: number) => {
      const shapes = icon.querySelectorAll<SVGGeometryElement>("path, line, polyline, polygon, circle, rect, ellipse");
      if (!shapes.length) return;

      let hasMeasuredShape = false;
      shapes.forEach((shape) => {
        try {
          const length = Math.max(shape.getTotalLength(), 1);
          shape.style.setProperty("--stroke-length", `${length}`);
          shape.style.strokeDasharray = `${length}`;
          shape.style.strokeDashoffset = `${length}`;
          hasMeasuredShape = true;
        } catch {
          /* ignore non-measurable shape */
        }
      });

      if (!hasMeasuredShape) return;
      icon.classList.add("is-draw-ready");

      requestAnimationFrame(() => {
        shapes.forEach((shape) => {
          shape.style.transition = `stroke-dashoffset 700ms cubic-bezier(0.22, 1, 0.36, 1) ${delayMs}ms`;
          shape.style.strokeDashoffset = "0";
        });
      });
    };

    document.querySelectorAll<HTMLElement>("#emocoes li[data-reveal]").forEach((item) => {
      const delay = Number.parseInt(item.style.getPropertyValue("--reveal-delay") || "0", 10) + 120;
      const runDraw = () => {
        if (item.dataset.drawDone === "1") return;
        item.dataset.drawDone = "1";
        item.querySelectorAll<SVGElement>(".icon-draw").forEach((icon) => setupIconDraw(icon, delay));
      };

      if (item.classList.contains("is-visible")) {
        runDraw();
        return;
      }

      const classObserver = new MutationObserver(() => {
        if (!item.classList.contains("is-visible")) return;
        classObserver.disconnect();
        runDraw();
      });

      classObserver.observe(item, { attributes: true, attributeFilter: ["class"] });
    });

    targets.forEach((node) => observer.observe(node));
  })();
</script>
