---
export interface Props {
  class?: string
}

const { class: className } = Astro.props
const avatarImage = "https://www.figma.com/api/mcp/asset/3e8fc2fb-5775-4700-a439-f0e1bf1a3d26"
import {
  AlarmClockOff,
  BadgeAlert,
  BatteryLow,
  Brain,
  CloudAlert,
  Target,
  Waves,
} from "lucide-react"

const emotionalSigns = [
  { label: "Cansaço constante", icon: BatteryLow },
  { label: "Se cobrar demais", icon: Target },
  { label: "Medo do futuro", icon: CloudAlert },
  { label: "Incerteza", icon: BadgeAlert },
  { label: "Sensação de esgotamento", icon: AlarmClockOff },
  { label: "Ansiedade", icon: Brain },
  { label: "Crises de ansiedade", icon: Waves },
]
---

<section class:list={["max-w-[1400px] mx-auto w-full py-16 md:py-40", className]}>
  <div class="flex  flex-col items-start justify-between gap-10 lg:flex-row lg:items-center lg:gap-[59px]">
   <div class="max-w-[562px] mx-auto">
    <span class="mb-4 inline-flex items-center gap-3 text-sm font-mono text-foreground">
      <span class="w-8 h-px bg-muted-foreground"></span>
  Emoções</span>
    <p class="max-w-[562px] font-heading font-medium text-4xl leading-tight tracking-[-1.92px] text-foreground md:text-5xl">
      Se você chegou até aqui, talvez esteja
    </p>
    <span class="font-light italic text-muted-foreground"> carregando muita coisa...</span>


    <div class="w-full mt-10">
      <div class="flex items-start gap-2.5">
        <img
          src={avatarImage}
          alt="Avatar da psicóloga"
          width="60"
          height="60"
          class="h-[60px] w-[60px] shrink-0 mt-4"
          loading="lazy"
        />

        <div class="flex min-w-0 flex-1 flex-col justify-center rounded-xl bg-white/10 px-5 py-4 backdrop-blur-[32px]">
          <p class="mb-4 text-[19px] leading-6 font-semibold text-foreground">Isso soa familiar?</p>

          <ul class="flex flex-wrap gap-x-3 gap-y-2">
            {emotionalSigns.map((item) => (
              <li class="inline-flex min-h-[24px] items-center gap-1.5 rounded-full border border-zinc-200 bg-white px-2.5 py-1 text-xs leading-tight font-semibold text-foreground">
                <item.icon className="size-3.5 shrink-0 text-muted-foreground" aria-hidden="true" />
                <span>{item.label}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
