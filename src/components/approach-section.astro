---
import { Button } from './ui/button'

export interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<section id="abordagem" class:list={["mx-auto w-full max-w-[1400px] py-16 md:py-24 lg:py-[98px] px-4", className]}>
  <div class="mx-auto flex w-full max-w-[560px] flex-col items-center gap-16 md:gap-20">
    <div class="flex w-full flex-col items-center gap-6 text-center">
      <div class="flex w-full flex-col items-center gap-2">
        <span class="inline-flex items-center gap-3 text-sm font-mono text-foreground">
          <span class="h-px w-8 bg-muted-foreground"></span>
          Abordagem
        </span>   
        <h2 class="font-heading text-4xl font-medium leading-tight tracking-[-1.2px] text-foreground md:text-5xl md:tracking-[-1.92px]">
          Qual <span class="font-light italic text-muted-foreground">abordagem</span>
          <br />
          utilizo na terapia?
        </h2>
      </div>

      <p class="text-base font-medium leading-normal tracking-[-0.64px] text-muted-foreground">
        Minha pratica e baseada na
        <span class="font-semibold text-foreground"> Terapia Cognitivo-Comportamental (TCC)</span>, com foco em promover
        clareza, autonomia e mudancas consistentes.
      </p>
    </div>

   <div class="w-full flex flex-col items-center gap-4">
    <Button variant="default" size="lg" className="mx-auto">
      Como funciona
    </Button>
    <div class="relative h-[212px] w-[212px]" aria-hidden="true">
      <div class="absolute left-1/2 top-1/2 h-[180px] w-[180px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#d9d6e9] blur-[44px]"></div>
      <div class="absolute left-[46%] top-[58%] h-[130px] w-[130px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#ff7f50]/40 blur-[42px]"></div>
      <div class="absolute left-[57%] top-[42%] h-[120px] w-[120px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#ff7f50]/45 blur-[42px]"></div>
    </div>
   </div>
  </div>
</section>
